{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "figcad",
  "main": "src/server.ts",
  "compatibility_date": "2026-04-01",
  // 빌드된 Vite 앱을 같은 Worker가 서빙 — 배포 1회, URL 1개
  "assets": {
    "directory": "../web/dist",
    "binding": "ASSETS"
  },
  "durable_objects": {
    "bindings": [{ "name": "Doc", "class_name": "Doc" }]
  },
  // 무료 플랜은 SQLite 기반 DO만 지원
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["Doc"] }],
  "observability": { "enabled": true }
}
